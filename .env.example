# Neon PostgreSQL (https://neon.tech) — required for Vercel/production
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Optional local SQLite (change prisma/schema.prisma provider to sqlite):
# DATABASE_URL="file:./dev.db"

# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# App URL (production: https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: email for membership renewal (Resend free tier)
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@yourdomain.com"
