# LOCAL (easiest — no account needed):
DATABASE_URL="file:./dev.db"

# PRODUCTION — Neon PostgreSQL (https://neon.tech) — also set prisma provider to postgresql
# DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# App URL (production: https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: email for membership renewal (Resend free tier)
# RESEND_API_KEY=""
# EMAIL_FROM="noreply@yourdomain.com"
